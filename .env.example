# Database (MySQL 8+)
DATABASE_URL=mysql://user:password@localhost:3306/utm_shortener_pro

# Optional separate vars (used if DATABASE_URL not set)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=utm_shortener_pro

# NextAuth (for future user accounts)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-long-random-string-in-production

# App
NEXT_PUBLIC_APP_NAME=UTM Shortener Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Note: TinyURL API key is entered by user in the app Settings modal and stored in browser localStorage only.